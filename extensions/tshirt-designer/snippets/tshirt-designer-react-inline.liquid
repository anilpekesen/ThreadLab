{% assign designer_app_url = 'https://app.printlabapp.com/designer-app/' %}
{% assign configured_designer_url = block.settings.designer_app_url | default: '' | strip %}
{% if configured_designer_url contains '/designer-app' %}
  {% assign designer_app_url = configured_designer_url %}
{% endif %}

<div
  class="dsgn-inline-react"
  data-designer-inline
  data-designer-url="{{ designer_app_url }}"
  data-product-id="{{ product.id }}"
  data-product-title="{{ product.title | escape }}"
  data-product-handle="{{ product.handle }}"
  data-front-image="{{ front_img }}"
  data-back-image="{{ back_img }}"
  data-shirt-color="{{ shirt_color | default: '#1C1C1E' }}"
  data-currency="{{ shop.currency }}"
  data-locale="{{ request.locale.iso_code | default: 'tr-TR' }}"
  data-single-variant-id="{{ block.settings.single_variant_id }}"
  data-double-variant-id="{{ block.settings.double_variant_id }}"
  data-single-price="{{ block.settings.single_price }}"
  data-double-price="{{ block.settings.double_price }}"
  data-surcharge-variant-id="{{ shop.metafields.printlabapp.surcharge_variant_id.value }}"
  data-product-variants="{{ product.variants | json | escape }}"
  data-selected-variant="{{ product.selected_or_first_available_variant | json | escape }}"
  data-option-names="{{ product.options | join: ',' | escape }}"
>
  <iframe
    class="dsgn-inline-react__frame"
    title="Tişört Tasarım Aracı"
    loading="eager"
    allow="camera; microphone"
  ></iframe>
</div>

<style>
  /* Always break out of the Shopify theme column — width: 100% alone is not enough */
  .dsgn-inline-react {
    position: relative;
    width: 100vw !important;
    max-width: 100vw;
    margin-left: calc(50% - 50vw);
    margin-right: calc(50% - 50vw);
    min-height: 960px;
    height: 960px;
    border-left: none;
    border-right: none;
    border-top: 1px solid #e5e7eb;
    border-bottom: 1px solid #e5e7eb;
    border-radius: 0;
    overflow: hidden;
    background: #f3f4f6;
  }

  .dsgn-inline-react__frame {
    display: block;
    width: 100%;
    min-height: 960px;
    height: 960px;
    border: 0;
    background: #f3f4f6;
    transform: translateZ(0);
    -webkit-transform: translateZ(0);
  }

  /* Mobile: taller to fit stacked canvas + sidebar */
  @media (max-width: 859px) {
    .dsgn-inline-react,
    .dsgn-inline-react__frame {
      min-height: 1320px;
      height: 1320px;
    }
  }
</style>

<script>
  (function() {
    var roots = document.querySelectorAll('[data-designer-inline]');
    if (!roots.length) return;

    function normalizeOptionName(value) {
      return String(value || '').toLocaleLowerCase('tr-TR').trim();
    }

    function detectOptionKeys(root) {
      var rawNames = (root.dataset.optionNames || '').split(',').map(function(s) { return String(s || '').trim(); }).filter(Boolean);
      var names = rawNames.map(function(s) { return normalizeOptionName(s); });
      var keys = ['option1', 'option2', 'option3'];
      var colorIndex = names.findIndex(function(name) {
        return name.indexOf('renk') !== -1 || name.indexOf('color') !== -1 || name.indexOf('colour') !== -1;
      });
      if (colorIndex < 0) colorIndex = 0;
      return {
        names: names,
        rawNames: rawNames,
        colorIndex: colorIndex,
        colorKey: keys[colorIndex] || 'option1'
      };
    }

    function variantImageSrc(variant) {
      return variant && variant.featured_image && variant.featured_image.src ? String(variant.featured_image.src) : '';
    }

    function optionIndexFromControl(control, keys, fallbackIndex) {
      var text = normalizeOptionName(
        control.getAttribute('name') ||
        control.getAttribute('data-option-name') ||
        control.getAttribute('aria-label') ||
        ''
      );
      var fieldset = control.closest ? control.closest('fieldset') : null;
      if (fieldset) {
        var legend = fieldset.querySelector('legend');
        if (legend) text += ' ' + normalizeOptionName(legend.textContent || '');
      }
      var label = control.id ? document.querySelector('label[for="' + CSS.escape(control.id) + '"]') : null;
      if (label) text += ' ' + normalizeOptionName(label.textContent || '');

      var index = keys.names.findIndex(function(name) {
        return name && (text.indexOf(name) !== -1 || name.indexOf(text) !== -1);
      });
      return index >= 0 ? index : fallbackIndex;
    }

    function readVisibleOptionValues(root, variants) {
      var keys = detectOptionKeys(root);
      var values = {};
      var seenValues = [];

      Array.from(document.querySelectorAll('variant-selects select, form[action*="/cart/add"] select[name^="options["]'))
        .forEach(function(select, index) {
          if (!select || !select.value) return;
          var value = String(select.value);
          var optionIndex = optionIndexFromControl(select, keys, index);
          values[optionIndex] = value;
          seenValues.push(value);
        });

      Array.from(document.querySelectorAll('variant-radios fieldset, form[action*="/cart/add"] fieldset'))
        .forEach(function(fieldset, index) {
          var checked = fieldset.querySelector('input[type="radio"]:checked');
          if (!checked || !checked.value) return;
          var value = String(checked.value);
          var optionIndex = optionIndexFromControl(checked, keys, index);
          values[optionIndex] = value;
          seenValues.push(value);
        });

      var colorOptions = Array.from(new Set(variants.map(function(variant) {
        return variant && variant[keys.colorKey] ? String(variant[keys.colorKey]) : '';
      }).filter(Boolean)));
      if (!values[keys.colorIndex]) {
        var selectedColor = seenValues.find(function(value) {
          return colorOptions.some(function(color) { return normalizeOptionName(color) === normalizeOptionName(value); });
        });
        if (selectedColor) values[keys.colorIndex] = selectedColor;
      }

      return { keys: keys, values: values };
    }

    function findVariantBySelectedOptions(root, variants) {
      if (!Array.isArray(variants) || !variants.length) return null;
      var selected = readVisibleOptionValues(root, variants);
      var optionIndexes = Object.keys(selected.values);
      if (!optionIndexes.length) return null;
      return variants.find(function(variant) {
        return optionIndexes.every(function(index) {
          var key = 'option' + (Number(index) + 1);
          return normalizeOptionName(variant[key]) === normalizeOptionName(selected.values[index]);
        });
      }) || null;
    }

    function resolveVariantImages(root, variants, selectedVariant) {
      var fallbackFront = root.dataset.frontImage || '';
      var fallbackBack = root.dataset.backImage || fallbackFront;
      if (!Array.isArray(variants) || !variants.length) {
        return { frontImage: fallbackFront, backImage: fallbackBack };
      }

      var keys = detectOptionKeys(root);
      var selectedColor = selectedVariant && selectedVariant[keys.colorKey] ? String(selectedVariant[keys.colorKey]) : '';
      var selectedImage = variantImageSrc(selectedVariant);
      var frontImage = '';
      var backImage = '';

      variants.forEach(function(variant) {
        if (selectedColor && String(variant[keys.colorKey] || '') !== selectedColor) return;
        var img = variantImageSrc(variant);
        if (!img) return;
        var printOption = normalizeOptionName(variant.option3);
        var hasFront = printOption.indexOf('ön') !== -1 || printOption.indexOf('on') !== -1 || printOption.indexOf('front') !== -1;
        var hasBack = printOption.indexOf('arka') !== -1 || printOption.indexOf('back') !== -1;
        if (!printOption && selectedVariant && String(variant.id) === String(selectedVariant.id)) {
          if (!frontImage) frontImage = img;
          if (!backImage) backImage = img;
          return;
        }
        if (hasFront && !frontImage) frontImage = img;
        if (hasBack && !backImage) backImage = img;
      });

      if (!frontImage && selectedImage) frontImage = selectedImage;
      if (!backImage && selectedImage) backImage = selectedImage;
      if (!frontImage && selectedColor) {
        var anySameColor = variants.find(function(variant) {
          return String(variant[keys.colorKey] || '') === selectedColor && variantImageSrc(variant);
        });
        if (anySameColor) frontImage = variantImageSrc(anySameColor);
      }
      if (!backImage && frontImage) backImage = frontImage;
      return {
        frontImage: frontImage || fallbackFront,
        backImage: backImage || fallbackBack || frontImage || fallbackFront
      };
    }

    function sendDesignerConfig(iframe, root) {
      if (!iframe || !iframe.contentWindow) return;
      var selectedVariant = null;
      var variants = [];
      try { variants = JSON.parse(root.dataset.productVariants || '[]'); } catch (err) { variants = []; }
      try { selectedVariant = JSON.parse(root.dataset.selectedVariant || 'null'); } catch (err) { selectedVariant = null; }
      var visibleSelectedVariant = findVariantBySelectedOptions(root, variants);
      if (visibleSelectedVariant) selectedVariant = visibleSelectedVariant;
      var selectedVariantInput = document.querySelector('form[action*="/cart/add"] [name="id"]');
      var selectedVariantId = selectedVariantInput && selectedVariantInput.value ? String(selectedVariantInput.value) : '';
      if (!visibleSelectedVariant && selectedVariantId && Array.isArray(variants)) {
        var liveVariant = variants.find(function(variant) { return String(variant.id) === selectedVariantId; });
        if (liveVariant) selectedVariant = liveVariant;
      }
      var resolvedImages = resolveVariantImages(root, variants, selectedVariant);
      iframe.contentWindow.postMessage({
        type: 'DESIGNER_INIT',
        config: {
          productId: root.dataset.productId || '',
          productHandle: root.dataset.productHandle || '',
          productTitle: root.dataset.productTitle || '',
          frontImage: resolvedImages.frontImage,
          backImage: resolvedImages.backImage,
          shirtColor: root.dataset.shirtColor || '#1C1C1E',
          variants: variants,
          selectedVariant: selectedVariant,
          optionNames: (root.dataset.optionNames || '').split(',').map(function(s) { return s.trim(); }).filter(Boolean),
          currency: root.dataset.currency || 'TRY',
          locale: root.dataset.locale || 'tr-TR',
          uploadEndpoint: '/apps/tshirt-designer/upload',
          shop: '{{ shop.permanent_domain }}',
          singleVariantId: root.dataset.singleVariantId || '',
          doubleVariantId: root.dataset.doubleVariantId || '',
          singlePrice: Number(root.dataset.singlePrice || 0),
          doublePrice: Number(root.dataset.doublePrice || 0),
          surchargeVariantId: root.dataset.surchargeVariantId || ''
        }
      }, '*');
    }

    roots.forEach(function(root) {
      if (root.dataset.bound === '1') return;
      root.dataset.bound = '1';

      var iframe = root.querySelector('.dsgn-inline-react__frame');
      if (!iframe) return;

      var baseUrl = root.dataset.designerUrl || 'https://app.printlabapp.com/designer-app/';
      iframe.src = baseUrl;
      iframe.addEventListener('load', function() {
        sendDesignerConfig(iframe, root);
        window.setTimeout(function() { sendDesignerConfig(iframe, root); }, 80);
        window.setTimeout(function() { sendDesignerConfig(iframe, root); }, 400);
        window.setTimeout(function() { sendDesignerConfig(iframe, root); }, 1200);
      });

      document.addEventListener('change', function(event) {
        var target = event.target;
        if (!target || !target.matches || !target.matches('form[action*="/cart/add"] [name="id"], form[action*="/cart/add"] select[name^="options["], form[action*="/cart/add"] input[type="radio"], variant-selects select, variant-radios input')) return;
        window.setTimeout(function() { sendDesignerConfig(iframe, root); }, 50);
      });
    });

    if (window.__dsgnInlineReactBound) return;
    window.__dsgnInlineReactBound = true;

    window.addEventListener('message', function(e) {
      if (!e.data || !e.data.type) return;

      if (e.data.type === 'DESIGNER_SCROLL_TO_TOP') {
        var behavior = e.data.behavior === 'auto' ? 'auto' : 'smooth';
        var targetRoot = roots[0];
        if (targetRoot) {
          var top = targetRoot.getBoundingClientRect().top + window.pageYOffset - 8;
          try {
            window.scrollTo({ top: Math.max(0, top), left: 0, behavior: behavior });
          } catch (_) {
            window.scrollTo(0, Math.max(0, top));
          }
        } else {
          try {
            window.scrollTo({ top: 0, left: 0, behavior: behavior });
          } catch (_) {
            window.scrollTo(0, 0);
          }
        }
        return;
      }

      if (e.data.type === 'DESIGNER_INACTIVE') {
        roots.forEach(function(r) { r.style.display = 'none'; });
        return;
      }

      if (e.data.type === 'DESIGNER_ADD_TO_CART') {
        var items = Array.isArray(e.data.items) ? e.data.items : [];
        var props = e.data.properties || {};
        if (!items.length && e.data.variantId) {
          items = [{
            variantId: e.data.variantId,
            quantity: e.data.quantity || 1
          }];
        }
        if (!items.length) return;

        var cartItems = items.map(function(item) {
          var id = parseInt(item.variantId || item.id, 10);
          var quantity = Math.max(1, parseInt(item.quantity || 1, 10) || 1);
          return {
            id: id,
            quantity: quantity,
            properties: Object.assign({}, props, item.properties || {}, item.size ? { 'Beden': item.size } : {})
          };
        }).filter(function(item) {
          return Number.isFinite(item.id) && item.id > 0;
        });

        if (!cartItems.length) {
          console.error('[PrintLab] Cart add blocked: invalid variant ids', items);
          window.alert('Sepete eklenemedi: ürün varyantı bulunamadı.');
          return;
        }

        fetch('/cart/add.js', {
          method: 'POST',
          headers: {
            'Content-Type': 'application/json',
            'Accept': 'application/json'
          },
          body: JSON.stringify({
            items: cartItems
          })
        })
          .then(function(res) {
            if (!res.ok) {
              return res.text().then(function(text) {
                var message = text || 'cart_add_failed';
                try {
                  var json = JSON.parse(text);
                  message = json.description || json.message || json.status || message;
                } catch (_) {}
                console.error('[PrintLab] Cart add failed', res.status, message, { items: cartItems });
                throw new Error(message);
              });
            }
            return res.json();
          })
          .then(function() {
            // Save design_token + image URLs to cart attributes so they survive
            // Cart Transform line item expansion and are readable from the order record.
            var cartAttrs = {};
            if (e.data.designToken) cartAttrs['design_token'] = e.data.designToken;
            if (props['_front_preview_url']) cartAttrs['_front_preview_url'] = props['_front_preview_url'];
            if (props['_front_print_url']) cartAttrs['_front_print_url'] = props['_front_print_url'];
            if (props['_back_preview_url']) cartAttrs['_back_preview_url'] = props['_back_preview_url'];
            if (props['_back_print_url']) cartAttrs['_back_print_url'] = props['_back_print_url'];
            var hasAttrs = Object.keys(cartAttrs).length > 0;
            if (hasAttrs) {
              fetch('/cart/update.js', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json', 'Accept': 'application/json' },
                body: JSON.stringify({ attributes: cartAttrs })
              }).then(function() {
                window.location.href = '/cart';
              }).catch(function() {
                window.location.href = '/cart';
              });
            } else {
              window.location.href = '/cart';
            }
          })
          .catch(function(err) {
            window.alert('Sepete eklenirken hata oluştu: ' + (err && err.message ? err.message : 'Bilinmeyen hata'));
          });
      }
    });
  })();
</script>
