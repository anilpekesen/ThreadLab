{% comment %}
  Full-screen designer modal powered by React app.
  Opens when user clicks "Tam Tasarım Aracını Aç" button.
{% endcomment %}

{% assign designer_app_url = block.settings.designer_app_url | default: '' %}
{% if designer_app_url == blank %}
  {% assign designer_app_url = shop.url | append: '/apps/tshirt-designer/designer' %}
{% endif %}

{% assign front_variant = product.variants | where: 'option3', 'Ön Baskı' | first %}
{% assign back_variant = product.variants | where: 'option3', 'Arka Baskı' | first %}
{% assign double_variant = product.variants | where: 'option3', 'Ön + Arka Baskı' | first %}

{% assign front_img = '' %}
{% if front_variant.featured_image %}
  {% assign front_img = front_variant.featured_image | image_url: width: 900 %}
{% elsif product.images[0] %}
  {% assign front_img = product.images[0] | image_url: width: 900 %}
{% endif %}
{% assign back_img = '' %}
{% if back_variant.featured_image %}
  {% assign back_img = back_variant.featured_image | image_url: width: 900 %}
{% elsif product.images[1] %}
  {% assign back_img = product.images[1] | image_url: width: 900 %}
{% endif %}

<button
  type="button"
  class="dsgn-open-modal-btn"
  data-designer-modal-open
  data-designer-url="{{ designer_app_url }}"
  data-product-id="{{ product.id }}"
  data-product-title="{{ product.title | escape }}"
  data-product-handle="{{ product.handle }}"
  data-front-image="{{ front_img }}"
  data-back-image="{{ back_img }}"
  data-shirt-color="{{ shirt_color | default: '#1C1C1E' }}"
  data-currency="{{ shop.currency }}"
  data-locale="{{ request.locale.iso_code | default: 'tr-TR' }}"
  data-single-variant-id="{{ front_variant.id | default: block.settings.single_variant_id }}"
  data-double-variant-id="{{ double_variant.id | default: block.settings.double_variant_id }}"
  data-single-price="{{ front_variant.price }}"
  data-double-price="{{ double_variant.price }}"
  data-product-variants="{{ product.variants | json | escape }}"
>
  <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
    <path d="M12 2L2 7l10 5 10-5-10-5z"/><path d="M2 17l10 5 10-5"/><path d="M2 12l10 5 10-5"/>
  </svg>
  Tasarım Aracını Aç
</button>

<!-- Modal overlay -->
<div id="dsgn-modal-overlay" style="display:none; position:fixed; inset:0; z-index:99999; background:rgba(0,0,0,0.85);">
  <div style="position:relative; width:100%; height:100%; display:flex; flex-direction:column;">
    <iframe
      id="dsgn-modal-iframe"
      style="flex:1; border:none; width:100%; height:100%;"
      allow="camera; microphone"
    ></iframe>
  </div>
</div>

<style>
.dsgn-open-modal-btn {
  display: inline-flex;
  align-items: center;
  gap: 8px;
  padding: 14px 24px;
  background: #6366f1;
  color: #fff;
  border: none;
  border-radius: 8px;
  font-size: 15px;
  font-weight: 600;
  cursor: pointer;
  transition: background 0.15s;
  width: 100%;
  justify-content: center;
  margin-top: 12px;
}
.dsgn-open-modal-btn:hover { background: #4f46e5; }
</style>

<script>
(function() {
  var btn = document.querySelector('[data-designer-modal-open]');
  var overlay = document.getElementById('dsgn-modal-overlay');
  var iframe = document.getElementById('dsgn-modal-iframe');
  if (!btn || !overlay || !iframe) return;

  btn.addEventListener('click', function() {
    var baseUrl = btn.dataset.designerUrl;
    var params = new URLSearchParams({
      productId: btn.dataset.productId || '',
      handle: btn.dataset.productHandle || '',
      title: btn.dataset.productTitle || '',
      front: btn.dataset.frontImage || '',
      back: btn.dataset.backImage || '',
      color: btn.dataset.shirtColor || '#1C1C1E',
      currency: btn.dataset.currency || 'TRY',
      locale: btn.dataset.locale || 'tr-TR',
      singleVariantId: btn.dataset.singleVariantId || '',
      doubleVariantId: btn.dataset.doubleVariantId || '',
      singlePrice: btn.dataset.singlePrice || '',
      doublePrice: btn.dataset.doublePrice || '',
      variants: btn.dataset.productVariants || '[]',
    });
    iframe.src = baseUrl + '?' + params.toString();
    overlay.style.display = 'block';
    document.body.style.overflow = 'hidden';
  });

  // Listen for messages from the designer iframe
  window.addEventListener('message', function(e) {
    if (!e.data || !e.data.type) return;

    if (e.data.type === 'DESIGNER_CLOSE') {
      overlay.style.display = 'none';
      document.body.style.overflow = '';
      iframe.src = '';
    }

    if (e.data.type === 'DESIGNER_ADD_TO_CART') {
      overlay.style.display = 'none';
      document.body.style.overflow = '';
      iframe.src = '';

      var props = e.data.properties || {};
      var items = e.data.items || [];

      if (!items.length) return;

      var cartItems = items.map(function(item) {
        var id = parseInt(item.variantId || item.id, 10);
        var quantity = Math.max(1, parseInt(item.quantity || 1, 10) || 1);
        return {
          id: id,
          quantity: quantity,
          properties: Object.assign({}, props, item.properties || {}, item.size ? { 'Beden': item.size } : {})
        };
      }).filter(function(item) {
        return Number.isFinite(item.id) && item.id > 0;
      });

      if (!cartItems.length) {
        console.error('[PrintLab] Cart add blocked: invalid variant ids', items);
        alert('Sepete eklenemedi: ürün varyantı bulunamadı.');
        return;
      }

      fetch('/cart/add.js', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({
          items: cartItems
        })
      }).then(function(res) {
        if (!res.ok) {
          return res.text().then(function(text) {
            var message = text || 'cart_add_failed';
            try {
              var json = JSON.parse(text);
              message = json.description || json.message || json.status || message;
            } catch (_) {}
            console.error('[PrintLab] Cart add failed', res.status, message, { items: cartItems });
            throw new Error(message);
          });
        }
        return res.json();
      }).then(function() {
        // Cart Transform expand strips line item properties from the order.
        // Save key design fields as cart attributes so they survive as note_attributes.
        return fetch('/cart/update.js', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({
            attributes: {
              design_token: props.design_token || '',
              _front_preview_url: props._front_preview_url || '',
              _front_print_url: props._front_print_url || '',
              _back_preview_url: props._back_preview_url || '',
              _back_print_url: props._back_print_url || ''
            }
          })
        });
      }).then(function() {
        window.location.href = '/cart';
      }).catch(function(err) {
        alert('Sepete eklenirken hata oluştu: ' + (err && err.message ? err.message : 'Bilinmeyen hata'));
      });
    }
  });
})();
</script>
