      </div>
    </div>

    <!-- Designs / Katmanlar panel -->
    <div class="dsgn-tp" data-tp="designs">
      <div class="dsgn-sheet-head">
        <strong>Şablon &amp; Kayıtlar</strong>
        <button type="button" class="dsgn-sheet-close" data-close-tool aria-label="Kapat">
