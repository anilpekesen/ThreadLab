<script>
(function () {
  var productImg = document.querySelector('[data-product-img]');
  if (!productImg) return;
  function populateThumbs() {
    var root = productImg.closest('.designer');
    if (!root) return;
    var frontSrc = root.dataset.frontImage || productImg.src;
    var backSrc  = root.dataset.backImage  || productImg.src;
    var tFront = root.querySelector('[data-view-thumb="front"]');
    var tBack  = root.querySelector('[data-view-thumb="back"]');
    if (tFront && frontSrc) tFront.src = frontSrc;
    if (tBack  && backSrc)  tBack.src  = backSrc;
  }
  if (productImg.complete && productImg.naturalWidth) {
    populateThumbs();
  } else {
    productImg.addEventListener('load', populateThumbs, { once: true });
  }
})();
</script>

